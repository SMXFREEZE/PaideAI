# Copy this file to .env and fill in your values
# Get your API key at: https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: tune behavior
TUTOR_MODEL=claude-sonnet-4-6
TUTOR_NAME=Professeur Sami
STUDENT_NAME=Sami
MICRO_QUIZ_INTERVAL_MINUTES=15
MAX_CONVERSATION_HISTORY=40

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30

# File upload limits
MAX_UPLOAD_MB=15
MAX_PDF_PAGES=60

# CORS — comma-separated allowed origins (use * for dev only)
ALLOWED_ORIGINS=*

# Optional: AWS (for production TTS / Textract)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
